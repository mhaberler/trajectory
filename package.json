{
  "name": "trajectory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "deploy": "DEPLOY_BASE=/apps/$npm_package_name/ bun run build && rsync -avz --delete dist/ mah@cloud.mah.priv.at:/var/www/cloud.mah.priv.at/apps/$npm_package_name/ && echo visit https://cloud.mah.priv.at/apps/$npm_package_name/"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.67.0",
    "eslint-plugin-vue": "~10.9.1",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.1",
    "oxlint": "~1.67.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
